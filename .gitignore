# Environnements Python
.venv/
venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Données : NE PAS versionner les CSV bruts (volumineux + données personnelles RGPD)
# -> fournis via OneDrive, voir data/README.md
data/raw/*.csv
data/processed/*.csv
data/processed/*.parquet
# Entrepôt SQLite : volumineux (~66 Mo) + contient des données personnelles (RGPD) -> régénérable via build_warehouse.py
data/processed/*.db
data/processed/*.sqlite

# Modèles entraînés (volumineux -> OneDrive)
volet-datascience/models/*.pkl
volet-datascience/models/*.joblib
*.mlflow
# Sorties modèles contenant des PDL identifiables + label fraude (RGPD) -> régénérables
volet-datascience/suspects_priorises.csv
volet-datascience/models/features.csv

# Dashboards HTML générés (~4,5 Mo chacun, Plotly embarqué) + exports KPI -> régénérables
volet-analyst/dashboards/*.html
volet-analyst/dashboards/*.csv
# (les figures PNG agrégées SONT versionnées : elles servent au rapport et aux slides)
scripts/_out/

# Secrets — JAMAIS de secrets en clair dans le repo (DevSecOps)
.env
*.key
*.pem
secrets/

